{
  "name": "seva-sahyog-supabase-seed",
  "version": "1.0.0",
  "description": "Seed + migration scripts for Seva-Sahyog Supabase database",
  "scripts": {
    "seed": "node seed_users.js",
    "migrate": "node migrate_from_sheets.js",
    "migrate:dry": "node migrate_from_sheets.js --dry-run",
    "migrate:users": "node migrate_from_sheets.js --only=users",
    "migrate:students": "node migrate_from_sheets.js --only=students",
    "migrate:exams": "node migrate_from_sheets.js --only=exams"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "dotenv": "^16.6.1",
    "googleapis": "^144.0.0",
    "xlsx": "^0.18.5"
  }
}
