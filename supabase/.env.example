# Seva-Sahyog — Supabase Seed & Migration Environment Variables
# Copy this to .env and fill in your values before running scripts.
# NEVER commit .env to version control.

# Your Supabase project URL
SUPABASE_URL=https://wplubsyhbvjmzvtrdgov.supabase.co

# Service Role key (Settings → API → "service_role" — NOT the anon key)
# This bypasses RLS and is required for seed + migration scripts.
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
