rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Reports folder — coordinators and admins can read; Cloud Functions write
    match /reports/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only Cloud Functions (admin SDK) can write
    }

    // Resources folder — teachers upload, everyone can read
    match /resources/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024; // 10MB max
    }
  }
}
