rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isCoordinator() {
      return isAuthenticated() && getUserRole() == 'coordinator';
    }

    function isTeacher() {
      return isAuthenticated() && getUserRole() == 'teacher';
    }

    function getUserZone() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.zone;
    }

    function getUserCentre() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.centre;
    }

    // ─── Users Collection ───────────────────────────────────────────

    match /users/{userId} {
      // Admin can read/write all users
      // Coordinators can read users in their zone
      // Teachers can read their own profile
      allow read: if isAdmin()
                  || (isCoordinator() && resource.data.zone == getUserZone())
                  || request.auth.uid == userId;
      allow create: if isAdmin();
      allow update: if isAdmin() || request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // ─── Students Collection ────────────────────────────────────────

    match /students/{studentId} {
      allow read: if isAdmin()
                  || (isCoordinator() && resource.data.zone == getUserZone())
                  || (isTeacher() && resource.data.teacherId == request.auth.uid);
      allow create: if isAdmin() || isTeacher();
      allow update: if isAdmin()
                    || (isTeacher() && resource.data.teacherId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ─── Attendance Collection ──────────────────────────────────────

    match /attendance/{recordId} {
      allow read: if isAdmin()
                  || (isCoordinator() && resource.data.zone == getUserZone())
                  || (isTeacher() && resource.data.teacherId == request.auth.uid);
      allow create: if isTeacher();
      allow update: if isTeacher() && resource.data.teacherId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ─── Zones Collection ───────────────────────────────────────────

    match /zones/{zoneId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Centres Collection ─────────────────────────────────────────

    match /centres/{centreId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Leaves Collection ──────────────────────────────────────────

    match /leaves/{leaveId} {
      allow read: if isAdmin()
                  || (isCoordinator() && resource.data.zone == getUserZone())
                  || (isTeacher() && resource.data.userId == request.auth.uid);
      allow create: if isTeacher();
      allow update: if isAdmin()
                    || (isCoordinator() && resource.data.zone == getUserZone())
                    || (isTeacher() && resource.data.userId == request.auth.uid && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    // ─── Exam Results Collection ────────────────────────────────────

    match /examResults/{resultId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher();
      allow update: if isAdmin()
                    || (isTeacher() && resource.data.teacherId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ─── Diary Entries Collection ───────────────────────────────────

    match /diaryEntries/{entryId} {
      allow read: if isAdmin()
                  || (isCoordinator() && resource.data.zone == getUserZone())
                  || (isTeacher() && resource.data.teacherId == request.auth.uid);
      allow create: if isTeacher();
      allow update, delete: if isTeacher() && resource.data.teacherId == request.auth.uid;
    }

    // ─── Resources Collection ───────────────────────────────────────

    match /resources/{resourceId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher();
      allow update, delete: if isAdmin()
                            || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }

    // ─── Announcements Collection ───────────────────────────────────

    match /announcements/{annId} {
      allow read: if isAdmin() || ((isCoordinator() || isTeacher()) && resource.data.zone == getUserZone());
      allow create: if isCoordinator() || isAdmin();
      allow delete: if isAdmin() || (isCoordinator() && resource.data.authorId == request.auth.uid);
    }
  }
}
